NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=

RESEND_API_KEY=
RESEND_FROM=Yide Acompanha <noreply@SEUDOMINIO.com>

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Opcional: usado pelo cron diário. Gerar com: openssl rand -hex 32
CRON_SECRET=

# Opcional: usado pela síntese de satisfação. Get em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Sentry (monitoramento de erros). Public DSN — exposto no client é seguro.
# Get em https://sentry.io/settings/<org>/projects/<project>/keys/
NEXT_PUBLIC_SENTRY_DSN=

# Opcional: token pra subir source maps no build (stack traces legíveis em prod).
# Get em https://sentry.io/settings/account/api/auth-tokens/ (scope: project:releases)
# Sem ele, Sentry funciona mas mostra código minificado nos erros.
SENTRY_AUTH_TOKEN=

# ─── Reuniões — Fase 1 (Google OAuth + Calendar sync) ─────────────────────
#
# Configurar em https://console.cloud.google.com/apis/credentials:
#  1. Criar projeto (ou reusar um existente)
#  2. Em "OAuth consent screen": user type = External, preencher dados básicos,
#     adicionar emails dos colaboradores em "Test users" enquanto não publicar.
#  3. Habilitar "Google Calendar API" em "Library"
#  4. Criar "OAuth 2.0 Client ID" tipo "Web application"
#  5. Em "Authorized redirect URIs", adicionar:
#       ${NEXT_PUBLIC_APP_URL}/api/auth/google-callback
#     (ex.: https://sistemaacompanha.yidedigital.com.br/api/auth/google-callback)
#  6. Copiar Client ID e Secret abaixo.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Reuniões — Fase 2+ (transcrição + IA)
OPENAI_API_KEY=
# Recall.ai é opcional — só pra Fase 4 (bot auto-join no Meet)
RECALL_API_KEY=
RECALL_WEBHOOK_SECRET=
