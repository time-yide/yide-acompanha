NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=

RESEND_API_KEY=
RESEND_FROM=Yide Acompanha <noreply@SEUDOMINIO.com>

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Opcional: usado pelo cron diário. Gerar com: openssl rand -hex 32
CRON_SECRET=

# Opcional: usado pela síntese de satisfação. Get em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Sentry (monitoramento de erros). Public DSN — exposto no client é seguro.
# Get em https://sentry.io/settings/<org>/projects/<project>/keys/
NEXT_PUBLIC_SENTRY_DSN=

# Opcional: token pra subir source maps no build (stack traces legíveis em prod).
# Get em https://sentry.io/settings/account/api/auth-tokens/ (scope: project:releases)
# Sem ele, Sentry funciona mas mostra código minificado nos erros.
SENTRY_AUTH_TOKEN=

# ─── Reuniões — Fase 2 (transcrição) ──────────────────────────────────────
# Provider primary: Groq (whisper-large-v3-turbo, $0.04/h = ~9× mais barato
# que OpenAI Whisper, mesma qualidade pra pt-BR).
# Get em https://console.groq.com/keys
GROQ_API_KEY=
#
# Fallback opcional: OpenAI Whisper ($0.36/h). Usado quando GROQ_API_KEY
# não tá configurada. Pode deixar vazio se já tem Groq.
# Get em https://platform.openai.com/api-keys
OPENAI_API_KEY=
#
# Opcional: forçar provider específico (groq | openai). Default: groq se
# tem GROQ_API_KEY, senão openai.
REUNIOES_TRANSCRIPTION_PROVIDER=
#
# Opcional: modelo Groq alternativo. Default: whisper-large-v3-turbo
# (mais rápido + mais barato). Alternativa: whisper-large-v3 (mais preciso,
# 3× mais caro mas ainda metade do OpenAI).
GROQ_WHISPER_MODEL=
